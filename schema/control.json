{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://loutrack2.local/schema/control.json",
  "title": "Host to Pi Control Message",
  "description": "Schema for control messages sent from Host to Raspberry Pi via TCP/JSON (JSON-RPC style)",
  "definitions": {
    "command": {
      "type": "string",
      "enum": [
        "start",
        "stop",
        "set_exposure",
        "set_gain",
        "set_fps",
        "set_focus",
        "set_threshold",
        "set_blob_diameter",
        "set_circularity_min",
        "mask_start",
        "mask_stop",
        "set_preview",
        "intrinsics_start",
        "intrinsics_stop",
        "intrinsics_clear",
        "intrinsics_get_corners",
        "intrinsics_status",
        "led_on",
        "led_off",
        "set_resolution",
        "ping"
      ],
      "description": "Command to execute on the Pi"
    },
    "params_start": {
      "type": "object",
      "description": "Parameters for start command",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["capture", "pose_capture", "wand_metric_capture"],
          "default": "capture"
        }
      }
    },
    "params_exposure": {
      "type": "object",
      "description": "Parameters for exposure setting",
      "required": ["value"],
      "properties": {
        "value": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100000,
          "description": "Exposure time in microseconds"
        }
      }
    },
    "params_gain": {
      "type": "object",
      "description": "Parameters for gain setting",
      "required": ["value"],
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Analog gain value"
        }
      }
    },
    "params_fps": {
      "type": "object",
      "description": "Parameters for FPS setting",
      "required": ["value"],
      "properties": {
        "value": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120,
          "description": "Target frames per second"
        }
      }
    },
    "params_focus": {
      "type": "object",
      "description": "Parameters for lens focus setting",
      "required": ["value"],
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0,
          "maximum": 20,
          "description": "LensPosition value"
        }
      }
    },
    "params_threshold": {
      "type": "object",
      "description": "Parameters for blob threshold setting",
      "required": ["value"],
      "properties": {
        "value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255,
          "description": "Binary threshold brightness"
        }
      }
    },
    "params_blob_diameter": {
      "type": "object",
      "description": "Parameters for blob diameter filter",
      "properties": {
        "min_px": {
          "type": "number",
          "minimum": 0,
          "description": "Minimum blob diameter in pixels"
        },
        "max_px": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Maximum blob diameter in pixels"
        }
      }
    },
    "params_circularity": {
      "type": "object",
      "description": "Parameters for minimum blob circularity",
      "required": ["value"],
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Circularity lower bound"
        }
      }
    },
    "params_preview": {
      "type": "object",
      "description": "Parameters for MJPEG preview rendering",
      "properties": {
        "render_enabled": {
          "type": "boolean",
          "description": "Enable/disable MJPEG render workload"
        },
        "overlays": {
          "type": "object",
          "properties": {
            "blob": {"type": "boolean"},
            "mask": {"type": "boolean"},
            "text": {"type": "boolean"},
            "charuco": {"type": "boolean"}
          },
          "additionalProperties": false
        },
        "charuco": {
          "type": "object",
          "properties": {
            "dictionary": {"type": "string"},
            "squares_x": {"type": "integer", "minimum": 2},
            "squares_y": {"type": "integer", "minimum": 2},
            "square_length_mm": {"type": "number", "exclusiveMinimum": 0},
            "marker_length_mm": {"type": "number", "exclusiveMinimum": 0}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "params_mask_start": {
      "type": "object",
      "description": "Parameters for static mask initialization",
      "required": ["threshold", "seconds"],
      "properties": {
        "threshold": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "hit_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "min_area": {
          "type": "integer",
          "minimum": 0
        },
        "dilate": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "oneOf": [
    {
      "title": "Request Message",
      "type": "object",
      "required": ["request_id", "camera_id", "cmd"],
      "properties": {
        "request_id": {
          "type": "string",
          "description": "Unique request identifier for request-response matching"
        },
        "camera_id": {
          "type": "string",
          "description": "Target camera/Pi identifier, or 'broadcast' for all"
        },
        "cmd": {
          "$ref": "#/definitions/command"
        },
        "params": {
          "type": "object",
          "description": "Command-specific parameters. Runtime validation is command-specific."
        }
      },
      "additionalProperties": false
    },
    {
      "title": "Response Message",
      "type": "object",
      "required": ["request_id", "camera_id", "ack"],
      "properties": {
        "request_id": {
          "type": "string",
          "description": "Matches the request_id from the request"
        },
        "camera_id": {
          "type": "string",
          "description": "Responding camera/Pi identifier"
        },
        "ack": {
          "type": "boolean",
          "description": "True if command was accepted, false otherwise"
        },
        "error_code": {
          "type": "integer",
          "minimum": 0,
          "description": "Error code if ack is false (0 = no error, >0 = error)"
        },
        "error_message": {
          "type": "string",
          "description": "Human-readable error message"
        },
        "result": {
          "type": "object",
          "description": "Optional result data from command execution"
        }
      },
      "additionalProperties": false
    }
  ]
}
